{
  "expo": {
    "name": "AKRIVO Skin",
    "slug": "akrivo-skin",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "akrivoskin",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "AKRIVO Skin lets you choose your own skin photo for skincare wellness insights and progress tracking."
      }
    },
    "android": {
      "usesCleartextTraffic": true,
      "permissions": [
        "READ_MEDIA_IMAGES"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "apiBaseUrl": ""
    }
  }
}
